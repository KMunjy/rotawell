# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Environment
NEXT_PUBLIC_ENVIRONMENT=development

# Upstash Redis (optional — for persistent rate limiting on Vercel)
# Create a free Redis database at https://console.upstash.com/
# Leave unset to use the in-memory fallback (fine for local dev)
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Sentry error monitoring
# Create a free account at https://sentry.io → New Project → Next.js
# Copy the DSN from Settings → Projects → <your project> → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
# Generate an auth token at https://sentry.io/settings/auth-tokens/
# Required to upload source maps during `next build` (optional for local dev)
SENTRY_AUTH_TOKEN=
